# DAA-LAB
#include <stdio.h>

void toh(int n, char x, char y, char z)
{
    if (n == 1)
    {
        printf("\nDisk- %d, %c to %c", n, x, y);
    }
    else
    {
        toh(n - 1, x, z, y);
        printf("\nDisk- %d, %c to %c", n, x, y);
        toh(n - 1, z, y, x);
    }
}

int main()
{
    int n;

    printf("Enter number of disks: ");
    scanf("%d", &n);

    if (n <= 0)
    {
        printf("Please enter a positive number.\n");
        return 0;
    }

    toh(n, 'X', 'Y', 'Z');

    return 0;
}

